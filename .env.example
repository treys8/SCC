# ----------------------------------------------------------------------------
# Supabase — find these in your project dashboard:
#   Project Settings → API
# ----------------------------------------------------------------------------

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public client key. Use the "publishable" key (sb_publishable_...) if your
# project has the new API keys, otherwise the legacy "anon" key. Safe to expose
# to the browser — RLS is what protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY secret. Use the "secret" key (sb_secret_...) or the legacy
# "service_role" key. Bypasses RLS — used only for admin actions like inviting
# members. NEVER prefix this with NEXT_PUBLIC_ and never import it into a
# Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------

# Canonical site URL, used to build auth redirect/callback links.
# Local: http://localhost:3000   Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

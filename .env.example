# ----------------------------------------------------------------------------
# Supabase — find these in your project dashboard:
#   Project Settings → API
# ----------------------------------------------------------------------------

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public client key. Use the "publishable" key (sb_publishable_...) if your
# project has the new API keys, otherwise the legacy "anon" key. Safe to expose
# to the browser — RLS is what protects your data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY secret. Use the "secret" key (sb_secret_...) or the legacy
# "service_role" key. Bypasses RLS — used only for admin actions like inviting
# members. NEVER prefix this with NEXT_PUBLIC_ and never import it into a
# Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------

# Canonical site URL, used to build auth redirect/callback links.
# Local: http://localhost:3000   Prod: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Web Push (VAPID) — generate the keypair once with:
#   npx web-push generate-vapid-keys
# Set all three in .env.local and in every Vercel environment.
# ----------------------------------------------------------------------------

# Public application server key. Safe to expose — the browser uses it to
# subscribe (PushManager.subscribe).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# SERVER-ONLY private key. Signs push requests. NEVER prefix with NEXT_PUBLIC_.
VAPID_PRIVATE_KEY=

# Contact identifier required by the Web Push spec — a mailto: or https: URL.
VAPID_SUBJECT=mailto:treyschill@gmail.com

# ----------------------------------------------------------------------------
# Cron — secret that authenticates Vercel Cron requests to /api/cron/*.
# Generate one with:  openssl rand -hex 32
# Set it in .env.local and in every Vercel environment. Vercel sends it as
# "Authorization: Bearer <CRON_SECRET>" on scheduled invocations.
# ----------------------------------------------------------------------------
CRON_SECRET=
